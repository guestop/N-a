rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Auth helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. User Avatars
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId)
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }

    // 2. App Assets (Thumbnails, etc)
    match /apps/{publisherId}/{appId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(publisherId)
                   && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isOwner(publisherId);
    }

    // 3. App ZIP Uploads
    match /uploads/{userId}/{appId}/{fileName} {
      // Publicly readable so the platform can run the app
      allow read: if true;
      
      // Only owner can upload. Validate size (<= 50MB) and type (ZIP)
      allow write: if isOwner(userId)
                   && request.resource.size <= 50 * 1024 * 1024
                   && request.resource.contentType.matches('application/zip|application/x-zip-compressed|multipart/x-zip');
      
      // Owner can delete
      allow delete: if isOwner(userId);
    }
  }
}
