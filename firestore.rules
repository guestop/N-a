rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read: if true;
      // Only the user themselves can create or update their own profile
      allow create, update: if isOwner(userId);
      // Deletions are blocked from the client for data integrity
      allow delete: if false;
    }

    // 2. Apps Collection
    match /apps/{appId} {
      // Marketplace is public, anyone can read published or draft apps
      allow read: if true;
      // Publisher must be authenticated and claim their own UID as publisherId
      allow create: if isAuthenticated() && request.resource.data.publisherId == request.auth.uid;
      // Publisher can only update or delete their own apps
      allow update, delete: if isOwner(resource.data.publisherId);
    }

    // 3. Analytics Collection
    match /analytics/{analyticsId} {
      // Only the app owner can read their analytics
      allow read: if isAuthenticated() && get(/databases/$(database)/documents/apps/$(resource.data.appId)).data.publisherId == request.auth.uid;
      
      // Because we use the Spark plan (no Cloud Functions), clients must track views directly.
      // We allow anyone to create/update an analytics record to track views (public).
      allow create, update: if true;
      
      // Nobody can delete analytics from the client
      allow delete: if false;
    }
  }
}
