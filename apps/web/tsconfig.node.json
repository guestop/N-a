{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noEmit": true,

    "composite": true,

    "types": ["node"]
  },
  "include": ["vite.config.ts", "tailwind.config.ts"]
}
